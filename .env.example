# Port used by the Nuxt development server.
# Tauri auto-detects the dev-server URL, so changing this is only needed
# when port 3030 is already occupied.
NEPTU_DEV_PORT=3030

# Override the app data directory in development mode.
# By default the Tauri app config directory is used; this variable lets
# you redirect settings and UI state to a local folder (e.g. for testing).
NEPTU_DEV_DIR=./.dev-files
